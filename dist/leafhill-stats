#!/usr/bin/env python3
"""leafhill-stats -- Claude Code token usage and cost dashboard.

Scans JSONL session files in ~/.claude/projects/ to compute live stats and
renders a comprehensive dashboard with bar charts, tables, sparklines, and
cost estimates.  Use --cached to fall back to ~/.claude/stats-cache.json.

Based on Threads post by ggfevans.
"""

import argparse
import glob
import json
import math
import os
import re
import sys
from collections import defaultdict
from datetime import datetime, timezone
from typing import Any

# ---------------------------------------------------------------------------
# Python version guard
# ---------------------------------------------------------------------------

if sys.version_info < (3, 10):
    print("Error: leafhill-stats requires Python 3.10 or later.")
    print(f"You are running Python {sys.version_info.major}.{sys.version_info.minor}.")
    sys.exit(1)

# ---------------------------------------------------------------------------
# TTY auto-detection
# ---------------------------------------------------------------------------

USE_COLOR: bool = sys.stdout.isatty()

# ---------------------------------------------------------------------------
# ANSI color helpers
# ---------------------------------------------------------------------------

_ANSI_CODES: dict[str, str] = {
    "red":     "\033[31m",
    "green":   "\033[32m",
    "yellow":  "\033[33m",
    "blue":    "\033[34m",
    "magenta": "\033[35m",
    "cyan":    "\033[36m",
    "white":   "\033[37m",
    "bold":    "\033[1m",
    "dim":     "\033[2m",
}
_ANSI_RESET = "\033[0m"


def color(text: str, color_name: str) -> str:
    """Apply ANSI color/style to *text*.

    Supported names: red, green, yellow, blue, magenta, cyan, white, bold, dim.
    Multiple styles can be combined with ``+`` (e.g. ``"bold+cyan"``).
    Returns plain text when color output is disabled.
    """
    if not USE_COLOR:
        return text
    prefix = ""
    for part in color_name.split("+"):
        code = _ANSI_CODES.get(part.strip().lower(), "")
        prefix += code
    if not prefix:
        return text
    return f"{prefix}{text}{_ANSI_RESET}"


# ---------------------------------------------------------------------------
# Number / currency formatting
# ---------------------------------------------------------------------------

def format_number(n: float) -> str:
    """Format large numbers with commas and appropriate suffixes (K, M, B).

    Numbers below 1 000 are returned as-is (with up to 2 decimal places).
    """
    abs_n = abs(n)
    if abs_n >= 1_000_000_000:
        return f"{n / 1_000_000_000:,.2f}B"
    if abs_n >= 1_000_000:
        return f"{n / 1_000_000:,.2f}M"
    if abs_n >= 1_000:
        return f"{n / 1_000:,.2f}K"
    if n == int(n):
        return f"{int(n):,}"
    return f"{n:,.2f}"


def format_currency(amount: float) -> str:
    """Format *amount* as USD.

    Uses 2 decimal places for values >= $1 and 4 decimal places for smaller
    values so that sub-cent amounts remain readable.
    """
    if abs(amount) >= 1:
        return f"${amount:,.2f}"
    return f"${amount:,.4f}"


# ---------------------------------------------------------------------------
# Section header
# ---------------------------------------------------------------------------

def section_header(title: str) -> str:
    """Render a section header using box-drawing characters.

    Example::

        +----------------------+
        |  My Section Title    |
        +----------------------+
    """
    inner = f"  {title}  "
    width = len(inner)
    top    = f"\u250c{'\u2500' * width}\u2510"
    middle = f"\u2502{inner}\u2502"
    bottom = f"\u2514{'\u2500' * width}\u2518"
    return f"{top}\n{middle}\n{bottom}"


# ---------------------------------------------------------------------------
# Horizontal bar chart
# ---------------------------------------------------------------------------

# Sub-block characters for fractional fill (eighths of a full block).
_BAR_BLOCKS = " \u258f\u258e\u258d\u258c\u258b\u258a\u2589\u2588"  # 0/8 .. 8/8


def _render_bar(fraction: float, width: int) -> str:
    """Return a bar string of *width* characters filled to *fraction* (0..1)."""
    fraction = max(0.0, min(1.0, fraction))
    full_blocks = fraction * width
    whole = int(full_blocks)
    remainder = full_blocks - whole

    eighth = int(round(remainder * 8))
    if eighth == 8:
        whole += 1
        eighth = 0

    bar = "\u2588" * whole
    if eighth > 0 and whole < width:
        bar += _BAR_BLOCKS[eighth]
    # Pad the rest with spaces so the bar is exactly *width* characters.
    bar = bar.ljust(width)
    return bar


def horizontal_bar(
    label: str,
    value: float,
    max_value: float,
    width: int = 40,
    bar_color: str = "cyan",
) -> str:
    """Render a single horizontal bar with label and value.

    Parameters
    ----------
    label:
        Text label shown to the left of the bar.
    value:
        Numeric value this bar represents.
    max_value:
        The value that corresponds to a full-width bar.
    width:
        Character width of the bar area (default 40).
    bar_color:
        ANSI color name for the filled portion.
    """
    fraction = value / max_value if max_value else 0.0
    bar_str = _render_bar(fraction, width)
    colored_bar = color(bar_str.rstrip(), bar_color) + " " * (width - len(bar_str.rstrip()))
    formatted_val = format_number(value)
    return f"  {label:<16s} {colored_bar} {formatted_val}"


def bar_chart(
    title: str,
    data: list[tuple[str, float]],
    width: int = 40,
    bar_color: str = "cyan",
) -> str:
    """Render a full horizontal bar chart with title and multiple bars.

    Parameters
    ----------
    title:
        Chart title rendered as a section header.
    data:
        Sequence of ``(label, value)`` pairs.
    width:
        Character width of each bar (default 40).
    bar_color:
        ANSI color name applied to bar fills.
    """
    if not data:
        return section_header(title)

    max_val = max(v for _, v in data)
    lines: list[str] = [section_header(title), ""]
    for label, value in data:
        lines.append(horizontal_bar(label, value, max_val, width=width, bar_color=bar_color))
    lines.append("")
    return "\n".join(lines)


# ---------------------------------------------------------------------------
# Sparkline
# ---------------------------------------------------------------------------

# Unicode block elements used for sparklines (height eighths, bottom-aligned).
_SPARK_CHARS = " \u2581\u2582\u2583\u2584\u2585\u2586\u2587\u2588"


def sparkline(values: list[float]) -> str:
    """Render a compact sparkline using Unicode block characters.

    Each value maps to one character whose height reflects relative magnitude.
    """
    if not values:
        return ""
    lo = min(values)
    hi = max(values)
    spread = hi - lo if hi != lo else 1.0
    parts: list[str] = []
    for v in values:
        idx = int(round(((v - lo) / spread) * 7))
        idx = max(0, min(7, idx))
        parts.append(_SPARK_CHARS[idx + 1])  # skip the space at index 0
    return "".join(parts)


# ---------------------------------------------------------------------------
# Table
# ---------------------------------------------------------------------------

def _visible_len(s: str) -> int:
    """Return the visible (non-ANSI) length of *s*."""
    return len(re.sub(r"\033\[[0-9;]*m", "", s))


def table(
    headers: list[str],
    rows: list[list[str]],
    alignments: list[str] | None = None,
) -> str:
    """Render a formatted table with box-drawing borders.

    Parameters
    ----------
    headers:
        Column header strings.
    rows:
        List of rows, each row a list of cell strings.
    alignments:
        Per-column alignment: ``"l"`` (left, default), ``"r"`` (right), or
        ``"c"`` (center).  If *None*, all columns are left-aligned.
    """
    num_cols = len(headers)
    if alignments is None:
        alignments = ["l"] * num_cols
    # Ensure alignments list is the right length.
    alignments = (alignments + ["l"] * num_cols)[:num_cols]

    # Compute column widths (based on visible length to handle ANSI codes).
    col_widths = [_visible_len(h) for h in headers]
    for row in rows:
        for i, cell in enumerate(row[:num_cols]):
            col_widths[i] = max(col_widths[i], _visible_len(cell))

    # Add 1 char padding on each side.
    padded = [w + 2 for w in col_widths]

    def _align(text: str, width: int, align: str) -> str:
        vis = _visible_len(text)
        pad_total = width - vis
        if pad_total < 0:
            pad_total = 0
        if align == "r":
            return " " * (pad_total - 1) + text + " "
        if align == "c":
            left = pad_total // 2
            right = pad_total - left
            return " " * left + text + " " * right
        # default left
        return " " + text + " " * (pad_total - 1)

    def _hline(left: str, mid: str, right: str) -> str:
        segments = ["\u2500" * w for w in padded]
        return left + mid.join(segments) + right

    top_border    = _hline("\u250c", "\u252c", "\u2510")
    header_sep    = _hline("\u251c", "\u253c", "\u2524")
    bottom_border = _hline("\u2514", "\u2534", "\u2518")

    # Header row.
    hdr_cells = [_align(headers[i], padded[i], alignments[i]) for i in range(num_cols)]
    header_row = "\u2502" + "\u2502".join(hdr_cells) + "\u2502"

    # Data rows.
    data_lines: list[str] = []
    for row in rows:
        cells: list[str] = []
        for i in range(num_cols):
            cell = row[i] if i < len(row) else ""
            cells.append(_align(cell, padded[i], alignments[i]))
        data_lines.append("\u2502" + "\u2502".join(cells) + "\u2502")

    parts = [top_border, header_row, header_sep] + data_lines + [bottom_border]
    return "\n".join(parts)


# ---------------------------------------------------------------------------
# Data layer — loading and aggregation
# ---------------------------------------------------------------------------

def scan_sessions(projects_dir: str = "~/.claude/projects") -> dict:
    """Scan all JSONL session files and compute stats.

    Returns a dict matching the stats-cache.json schema so all downstream
    functions work unchanged:
    {
        "dailyActivity": [{date, messageCount, sessionCount, toolCallCount}],
        "dailyModelTokens": [{date, tokensByModel: {model: total_tokens}}],
        "modelUsage": {model: {inputTokens, outputTokens, cacheReadInputTokens,
                               cacheCreationInputTokens}},
        "totalSessions": N,
        "totalMessages": N,
        "longestSession": {sessionId, duration, messageCount, timestamp},
        "firstSessionDate": "ISO",
        "hourCounts": {hour: count}
    }
    """
    expanded = os.path.expanduser(projects_dir)

    # Find all *.jsonl files, skipping subagents/ subdirectories.
    jsonl_files: list[str] = []
    for root, dirs, files in os.walk(expanded):
        # Prune subagents directories so os.walk doesn't descend into them.
        dirs[:] = [d for d in dirs if d != "subagents"]
        for fname in files:
            if fname.endswith(".jsonl"):
                jsonl_files.append(os.path.join(root, fname))

    # Per-day accumulators.
    daily_sessions: dict[str, set[str]] = defaultdict(set)        # date -> set of sessionIds
    daily_messages: dict[str, int] = defaultdict(int)              # date -> message count
    daily_tool_calls: dict[str, int] = defaultdict(int)            # date -> tool_use count
    daily_model_tokens: dict[str, dict[str, int]] = defaultdict(lambda: defaultdict(int))

    # Global model usage accumulators.
    model_usage: dict[str, dict[str, int]] = defaultdict(
        lambda: {"inputTokens": 0, "outputTokens": 0,
                 "cacheReadInputTokens": 0, "cacheCreationInputTokens": 0}
    )

    # Session tracking for longest session / hour counts.
    session_timestamps: dict[str, list[str]] = defaultdict(list)   # sessionId -> [timestamps]
    session_message_counts: dict[str, int] = defaultdict(int)      # sessionId -> message count
    hour_counts: dict[int, int] = defaultdict(int)                 # hour -> session count
    sessions_seen_for_hour: set[str] = set()

    total_messages = 0

    for fpath in jsonl_files:
        # Collect all lines grouped by requestId for deduplication.
        request_chunks: dict[str, list[dict]] = defaultdict(list)
        user_lines: list[dict] = []
        other_lines: list[dict] = []  # assistant lines without requestId

        try:
            with open(fpath, "r", encoding="utf-8") as f:
                for raw_line in f:
                    raw_line = raw_line.strip()
                    if not raw_line:
                        continue
                    try:
                        line = json.loads(raw_line)
                    except (json.JSONDecodeError, ValueError):
                        continue

                    line_type = line.get("type")
                    if line_type == "user":
                        user_lines.append(line)
                    elif line_type == "assistant":
                        rid = line.get("requestId")
                        if rid:
                            request_chunks[rid].append(line)
                        else:
                            other_lines.append(line)
        except (OSError, IOError):
            continue

        # --- Process user messages ---
        for uline in user_lines:
            ts = uline.get("timestamp", "")
            sid = uline.get("sessionId", "")
            date_str = ts[:10] if len(ts) >= 10 else ""
            if not date_str:
                continue

            daily_messages[date_str] += 1
            total_messages += 1
            if sid:
                daily_sessions[date_str].add(sid)
                session_timestamps[sid].append(ts)
                session_message_counts[sid] += 1

            # Count tool_use blocks in user message content (tool_result comes
            # from tool_result type lines, not user lines — tool calls are in
            # assistant messages).  User messages don't contain tool_use.

        # --- Deduplicate assistant messages by requestId ---
        # For each requestId, keep only the last chunk (final cumulative usage).
        final_assistant_lines: list[dict] = []
        for rid, chunks in request_chunks.items():
            final_assistant_lines.append(chunks[-1])
        # Also include assistant lines that had no requestId.
        final_assistant_lines.extend(other_lines)

        # --- Process deduplicated assistant messages ---
        for aline in final_assistant_lines:
            ts = aline.get("timestamp", "")
            sid = aline.get("sessionId", "")
            date_str = ts[:10] if len(ts) >= 10 else ""
            if not date_str:
                continue

            daily_messages[date_str] += 1
            total_messages += 1
            if sid:
                daily_sessions[date_str].add(sid)
                session_timestamps[sid].append(ts)
                session_message_counts[sid] += 1

            msg = aline.get("message", {})
            model = msg.get("model", "")
            usage = msg.get("usage", {})
            content = msg.get("content", [])

            # Count tool_use blocks in assistant content.
            if isinstance(content, list):
                for block in content:
                    if isinstance(block, dict) and block.get("type") == "tool_use":
                        daily_tool_calls[date_str] += 1

            # Token accounting. Skip synthetic/internal models.
            if model and usage and not model.startswith("<"):
                inp = usage.get("input_tokens", 0)
                out = usage.get("output_tokens", 0)
                cache_read = usage.get("cache_read_input_tokens", 0)
                cache_create = usage.get("cache_creation_input_tokens", 0)

                model_usage[model]["inputTokens"] += inp
                model_usage[model]["outputTokens"] += out
                model_usage[model]["cacheReadInputTokens"] += cache_read
                model_usage[model]["cacheCreationInputTokens"] += cache_create

                total_day = inp + out + cache_read + cache_create
                daily_model_tokens[date_str][model] += total_day

    # --- Compute hour counts and longest session ---
    longest_session: dict = {"sessionId": "", "duration": 0, "messageCount": 0, "timestamp": ""}

    for sid, ts_list in session_timestamps.items():
        if not ts_list:
            continue
        sorted_ts = sorted(ts_list)
        first_ts = sorted_ts[0]
        last_ts = sorted_ts[-1]

        # Hour of first timestamp for this session (count each session once).
        if sid not in sessions_seen_for_hour:
            sessions_seen_for_hour.add(sid)
            try:
                hour = int(first_ts[11:13])
                hour_counts[hour] += 1
            except (ValueError, IndexError):
                pass

        # Duration in milliseconds.
        try:
            t0 = datetime.fromisoformat(first_ts.replace("Z", "+00:00"))
            t1 = datetime.fromisoformat(last_ts.replace("Z", "+00:00"))
            duration_ms = int((t1 - t0).total_seconds() * 1000)
        except (ValueError, TypeError):
            duration_ms = 0

        if duration_ms > longest_session["duration"]:
            longest_session = {
                "sessionId": sid,
                "duration": duration_ms,
                "messageCount": session_message_counts.get(sid, 0),
                "timestamp": first_ts,
            }

    # --- Build dailyActivity ---
    all_dates = sorted(set(daily_messages.keys()) | set(daily_sessions.keys()))
    daily_activity = []
    for d in all_dates:
        daily_activity.append({
            "date": d,
            "messageCount": daily_messages.get(d, 0),
            "sessionCount": len(daily_sessions.get(d, set())),
            "toolCallCount": daily_tool_calls.get(d, 0),
        })

    # --- Build dailyModelTokens ---
    daily_model_tokens_list = []
    for d in all_dates:
        tokens_by_model = dict(daily_model_tokens.get(d, {}))
        if tokens_by_model:
            daily_model_tokens_list.append({
                "date": d,
                "tokensByModel": tokens_by_model,
            })

    # --- Total sessions ---
    all_session_ids: set[str] = set()
    for sids in daily_sessions.values():
        all_session_ids.update(sids)

    first_date = all_dates[0] if all_dates else ""

    return {
        "dailyActivity": daily_activity,
        "dailyModelTokens": daily_model_tokens_list,
        "modelUsage": dict(model_usage),
        "totalSessions": len(all_session_ids),
        "totalMessages": total_messages,
        "longestSession": longest_session,
        "firstSessionDate": first_date,
        "hourCounts": {str(k): v for k, v in hour_counts.items()},
    }


def _merge_cache_data(live_data: dict, cache_path: str) -> dict:
    """Merge stats-cache.json data for dates not covered by the live scan.

    JSONL files may be cleaned up over time, so the cache can hold historical
    data (e.g. Dec 2025) that no longer exists in session files.
    """
    expanded = os.path.expanduser(cache_path)
    try:
        with open(expanded, "r", encoding="utf-8") as f:
            cache = json.load(f)
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        return live_data

    live_dates = {e["date"] for e in live_data.get("dailyActivity", [])}

    # Add daily activity entries from cache for dates not in live data.
    for entry in cache.get("dailyActivity", []):
        if entry.get("date") not in live_dates:
            live_data["dailyActivity"].append(entry)
    live_data["dailyActivity"].sort(key=lambda x: x.get("date", ""))

    # Add daily model tokens for missing dates.
    live_token_dates = {e["date"] for e in live_data.get("dailyModelTokens", [])}
    for entry in cache.get("dailyModelTokens", []):
        if entry.get("date") not in live_token_dates:
            live_data["dailyModelTokens"].append(entry)
    live_data["dailyModelTokens"].sort(key=lambda x: x.get("date", ""))

    # Merge model usage — add cache-only models, sum cache values for
    # models that only appear in cache dates.
    for model, usage in cache.get("modelUsage", {}).items():
        if model.startswith("<"):
            continue
        if model not in live_data.get("modelUsage", {}):
            live_data.setdefault("modelUsage", {})[model] = usage
        else:
            # For models in both, check if cache has additional tokens from
            # dates not in live data.  Since we can't perfectly separate,
            # keep the live data as authoritative for overlapping models.
            pass

    # Update totals.
    cache_only_sessions = sum(
        e.get("sessionCount", 0) for e in cache.get("dailyActivity", [])
        if e.get("date") not in live_dates
    )
    cache_only_messages = sum(
        e.get("messageCount", 0) for e in cache.get("dailyActivity", [])
        if e.get("date") not in live_dates
    )
    live_data["totalSessions"] = live_data.get("totalSessions", 0) + cache_only_sessions
    live_data["totalMessages"] = live_data.get("totalMessages", 0) + cache_only_messages

    # Use earliest first date.
    cache_first = cache.get("firstSessionDate", "")
    live_first = live_data.get("firstSessionDate", "")
    if cache_first and (not live_first or cache_first < live_first):
        live_data["firstSessionDate"] = cache_first

    # Keep longest session from either source.
    cache_longest = cache.get("longestSession", {})
    live_longest = live_data.get("longestSession", {})
    if cache_longest.get("duration", 0) > live_longest.get("duration", 0):
        live_data["longestSession"] = cache_longest

    # Merge hour counts.
    for hour, count in cache.get("hourCounts", {}).items():
        h = str(hour)
        live_data.setdefault("hourCounts", {})[h] = (
            live_data.get("hourCounts", {}).get(h, 0) + count
        )

    return live_data


def load_stats(path: str = "~/.claude/stats-cache.json", live: bool = True) -> dict:
    """Load stats, either live from JSONL session files or from cache.

    When *live* is True (default), scans ``~/.claude/projects/`` for JSONL
    session files, then merges any historical data from *path* (stats-cache.json)
    for dates no longer present in the JSONL files.
    When *live* is False, reads directly from *path*.
    """
    if live:
        try:
            data = scan_sessions()
            return _merge_cache_data(data, path)
        except Exception:
            pass  # Fall through to cache file.

    expanded = os.path.expanduser(path)
    with open(expanded, "r", encoding="utf-8") as f:
        return json.load(f)


def get_monthly_breakdown(data: dict) -> list[dict]:
    """Aggregate dailyActivity by month.

    Return [{month: "2025-12", sessions: N, messages: N, tool_calls: N}].
    """
    monthly: dict[str, dict[str, int]] = defaultdict(lambda: {"sessions": 0, "messages": 0, "tool_calls": 0})
    for entry in data.get("dailyActivity", []):
        date_str = entry.get("date", "")
        if len(date_str) < 7:
            continue
        month = date_str[:7]
        monthly[month]["sessions"] += entry.get("sessionCount", 0)
        monthly[month]["messages"] += entry.get("messageCount", 0)
        monthly[month]["tool_calls"] += entry.get("toolCallCount", 0)

    return sorted(
        [{"month": m, **counts} for m, counts in monthly.items()],
        key=lambda x: x["month"],
    )


def get_daily_stats(data: dict) -> list[dict]:
    """Return daily activity with token usage merged in.

    [{date, sessions, messages, tool_calls, tokens_by_model: {}}]
    """
    token_map: dict[str, dict[str, int]] = {}
    for entry in data.get("dailyModelTokens", []):
        date_str = entry.get("date", "")
        token_map[date_str] = entry.get("tokensByModel", {})

    results: list[dict] = []
    for entry in data.get("dailyActivity", []):
        date_str = entry.get("date", "")
        results.append({
            "date": date_str,
            "sessions": entry.get("sessionCount", 0),
            "messages": entry.get("messageCount", 0),
            "tool_calls": entry.get("toolCallCount", 0),
            "tokens_by_model": token_map.get(date_str, {}),
        })

    return sorted(results, key=lambda x: x["date"])


def get_peak_days(data: dict, top_n: int = 5) -> list[dict]:
    """Return the top N days by total token usage."""
    daily = get_daily_stats(data)
    for day in daily:
        day["total_tokens"] = sum(day.get("tokens_by_model", {}).values())
    ranked = sorted(daily, key=lambda x: x["total_tokens"], reverse=True)
    return ranked[:top_n]


def get_model_usage(data: dict) -> dict:
    """Return modelUsage directly, keyed by model name."""
    return data.get("modelUsage", {})


def get_hourly_distribution(data: dict) -> dict[int, int]:
    """Return hourCounts as {hour: count}."""
    raw = data.get("hourCounts", {})
    return {int(k): v for k, v in raw.items()}


def estimate_costs(model_usage: dict, pricing: dict) -> dict:
    """Calculate estimated costs per model.

    pricing format: {model: {input: $/M, output: $/M, cache_read: $/M, cache_write: $/M}}.
    Return {model: {input_cost, output_cost, cache_read_cost, cache_write_cost, total}}.
    """
    results: dict[str, dict[str, float]] = {}
    for model, usage in model_usage.items():
        prices = pricing.get(model, {})
        input_cost = usage.get("inputTokens", 0) * prices.get("input", 0) / 1_000_000
        output_cost = usage.get("outputTokens", 0) * prices.get("output", 0) / 1_000_000
        cache_read_cost = usage.get("cacheReadInputTokens", 0) * prices.get("cache_read", 0) / 1_000_000
        cache_write_cost = usage.get("cacheCreationInputTokens", 0) * prices.get("cache_write", 0) / 1_000_000
        total = input_cost + output_cost + cache_read_cost + cache_write_cost
        results[model] = {
            "input_cost": round(input_cost, 6),
            "output_cost": round(output_cost, 6),
            "cache_read_cost": round(cache_read_cost, 6),
            "cache_write_cost": round(cache_write_cost, 6),
            "total": round(total, 6),
        }
    return results


def estimate_daily_costs(daily_stats: list[dict], model_usage: dict, pricing: dict) -> list[dict]:
    """Estimate daily costs.

    Since dailyModelTokens only has total tokens per model per day (not broken
    down by type), distribute the cost proportionally based on the overall model
    usage ratios. Return [{date, cost, tokens}].
    """
    # Precompute cost-per-token ratio for each model based on aggregate usage.
    cost_per_token: dict[str, float] = {}
    model_costs = estimate_costs(model_usage, pricing)
    for model, usage in model_usage.items():
        total_tokens = (
            usage.get("inputTokens", 0)
            + usage.get("outputTokens", 0)
            + usage.get("cacheReadInputTokens", 0)
            + usage.get("cacheCreationInputTokens", 0)
        )
        total_cost = model_costs.get(model, {}).get("total", 0)
        cost_per_token[model] = total_cost / total_tokens if total_tokens > 0 else 0

    results: list[dict] = []
    for day in daily_stats:
        tokens_by_model = day.get("tokens_by_model", {})
        day_tokens = sum(tokens_by_model.values())
        day_cost = 0.0
        for model, tokens in tokens_by_model.items():
            day_cost += tokens * cost_per_token.get(model, 0)
        results.append({
            "date": day.get("date", ""),
            "cost": round(day_cost, 6),
            "tokens": day_tokens,
        })

    return sorted(results, key=lambda x: x["date"])


def estimate_monthly_costs(daily_costs: list[dict]) -> list[dict]:
    """Aggregate daily costs by month. Return [{month, cost, tokens}]."""
    monthly: dict[str, dict[str, float]] = defaultdict(lambda: {"cost": 0.0, "tokens": 0})
    for entry in daily_costs:
        date_str = entry.get("date", "")
        if len(date_str) < 7:
            continue
        month = date_str[:7]
        monthly[month]["cost"] += entry.get("cost", 0)
        monthly[month]["tokens"] += entry.get("tokens", 0)

    return sorted(
        [{"month": m, "cost": round(v["cost"], 6), "tokens": v["tokens"]} for m, v in monthly.items()],
        key=lambda x: x["month"],
    )


def get_summary(data: dict) -> dict:
    """Return overview: total_sessions, total_messages, first_date, last_date,
    longest_session_duration_hours, longest_session_messages.
    """
    daily = data.get("dailyActivity", [])
    dates = sorted(e.get("date", "") for e in daily if e.get("date"))
    longest = data.get("longestSession", {})
    duration_ms = longest.get("duration", 0)
    duration_hours = round(duration_ms / 3_600_000, 2)

    return {
        "total_sessions": data.get("totalSessions", 0),
        "total_messages": data.get("totalMessages", 0),
        "first_date": dates[0] if dates else None,
        "last_date": dates[-1] if dates else None,
        "longest_session_duration_hours": duration_hours,
        "longest_session_messages": longest.get("messageCount", 0),
    }


# ---------------------------------------------------------------------------
# Pricing per million tokens (as of March 2026)
# ---------------------------------------------------------------------------

_PRICING_TIERS = {
    "opus-4-5": {"input": 5.00, "output": 25.00, "cache_read": 0.50, "cache_write": 6.25},
    "opus-4-6": {"input": 5.00, "output": 25.00, "cache_read": 0.50, "cache_write": 6.25},
    "sonnet-4-6": {"input": 3.00, "output": 15.00, "cache_read": 0.30, "cache_write": 3.75},
    "haiku-4-5": {"input": 1.00, "output": 5.00, "cache_read": 0.10, "cache_write": 1.25},
}

# Fallback pricing for unknown models (use Sonnet rates as middle ground).
_DEFAULT_PRICING = {"input": 3.00, "output": 15.00, "cache_read": 0.30, "cache_write": 3.75}

_FRIENDLY_NAMES = {
    "opus-4-5": "Opus 4.5",
    "opus-4-6": "Opus 4.6",
    "sonnet-4-6": "Sonnet 4.6",
    "haiku-4-5": "Haiku 4.5",
}


def _match_model_tier(model: str) -> str | None:
    """Match a model ID (with or without date suffix) to a pricing tier key."""
    for tier_key in _PRICING_TIERS:
        if tier_key in model:
            return tier_key
    return None


def _resolve_pricing(model_usage: dict) -> dict:
    """Build a pricing dict keyed by actual model IDs, using tier matching."""
    pricing: dict[str, dict] = {}
    for model in model_usage:
        tier = _match_model_tier(model)
        if tier:
            pricing[model] = _PRICING_TIERS[tier]
        else:
            pricing[model] = _DEFAULT_PRICING
    return pricing


def _friendly_model(name: str) -> str:
    """Shorten model IDs for display."""
    tier = _match_model_tier(name)
    if tier:
        return _FRIENDLY_NAMES.get(tier, name)
    return name


