                        help="Use stats-cache.json instead of scanning session files")
    parser.add_argument("--no-color", action="store_true",
                        help="Disable colored output")

    args = parser.parse_args()

    # Apply color settings: disabled if --no-color or non-TTY.
    if args.no_color:
        USE_COLOR = False

