def render_cost_estimates(data: dict) -> str:
    model_usage = get_model_usage(data)
    if not model_usage:
        return ""

    pricing = _resolve_pricing(model_usage)
    costs = estimate_costs(model_usage, pricing)

    # Per-model cost breakdown.
    rows = []
    grand_total = 0.0
    for model, c in costs.items():
        grand_total += c["total"]
        rows.append([
            color(_friendly_model(model), "bold+cyan"),
            format_currency(c["input_cost"]),
            format_currency(c["output_cost"]),
            format_currency(c["cache_read_cost"]),
            format_currency(c["cache_write_cost"]),
            color(format_currency(c["total"]), "bold+green"),
        ])

    lines = [
        section_header("Estimated Costs (All Time)"),
        "",
        table(
            ["Model", "Input", "Output", "Cache Read", "Cache Write", "Total"],
            rows,
            ["l", "r", "r", "r", "r", "r"],
        ),
        "",
        f"  {color('Grand Total:', 'bold')} {color(format_currency(grand_total), 'bold+green')}",
        "",
    ]

    # Monthly costs.
    daily = get_daily_stats(data)
    daily_costs = estimate_daily_costs(daily, model_usage, pricing)
    monthly_costs = estimate_monthly_costs(daily_costs)

    if monthly_costs:
        lines.append(bar_chart(
            "Monthly Cost Estimate",
            [(mc["month"], mc["cost"]) for mc in monthly_costs],
            bar_color="green",
        ))

        mc_rows = []
        for mc in monthly_costs:
            mc_rows.append([
                mc["month"],
                format_number(mc["tokens"]),
                color(format_currency(mc["cost"]), "bold+green"),
            ])
        lines.append(table(
            ["Month", "Tokens", "Est. Cost"],
            mc_rows,
            ["l", "r", "r"],
        ))
        lines.append("")

    # Daily costs.
    if daily_costs:
        dc_rows = []
        for dc in daily_costs:
            dc_rows.append([
                dc["date"],
                format_number(dc["tokens"]),
                format_currency(dc["cost"]),
            ])
        lines.append(section_header("Daily Cost Estimate"))
        lines.append("")
        lines.append(table(
            ["Date", "Tokens", "Est. Cost"],
            dc_rows,
            ["l", "r", "r"],
        ))
        lines.append("")

    return "\n".join(lines)


def render_hourly_distribution(data: dict) -> str:
    hours = get_hourly_distribution(data)
    if not hours:
        return ""

    chart_data = []
    for h in range(24):
        count = hours.get(h, 0)
        if count > 0:
            label = f"{h:02d}:00"
            chart_data.append((label, count))

    if not chart_data:
