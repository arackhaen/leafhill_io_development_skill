        epilog="Based on Threads post by ggfevans",
    )
    parser.add_argument("path", nargs="?", default="~/.claude/stats-cache.json",
                        help="Path to stats-cache.json (default: ~/.claude/stats-cache.json)")
    parser.add_argument("--all", action="store_true", dest="show_all",
                        help="Show full daily history (default: last 30 days)")
