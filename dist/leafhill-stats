def render_daily_stats(data: dict, show_all: bool = False) -> str:
    daily = get_daily_stats(data)
    if not daily:
        return ""

    model_usage = get_model_usage(data)
    pricing = _resolve_pricing(model_usage)
    daily_costs = estimate_daily_costs(daily, model_usage, pricing)
    cost_map = {dc["date"]: dc for dc in daily_costs}

    # Sparklines for quick visual.
    msg_values = [d["messages"] for d in daily]
    tok_values = [sum(d["tokens_by_model"].values()) for d in daily]

    # Determine which days to display.
    truncated = False
    display_daily = daily
    if not show_all and len(daily) > 30:
        display_daily = daily[-30:]
        truncated = True

    rows = []
    for d in display_daily:
        total_tok = sum(d["tokens_by_model"].values())
        dc = cost_map.get(d["date"], {})
        rows.append([
            d["date"],
            str(d["sessions"]),
            format_number(d["messages"]),
            format_number(d["tool_calls"]),
            format_number(total_tok),
            format_currency(dc.get("cost", 0)),
        ])

    lines = [
        section_header("Daily Stats"),
        "",
        f"  Messages:  {sparkline(msg_values)}",
        f"  Tokens:    {sparkline(tok_values)}",
        "",
        table(
            ["Date", "Sess", "Messages", "Tools", "Tokens", "Est. Cost"],
            rows,
            ["l", "r", "r", "r", "r", "r"],
        ),
    ]

    if truncated:
        lines.append("  Showing last 30 days. Use --all to see full history.")

    lines.append("")
    return "\n".join(lines)


